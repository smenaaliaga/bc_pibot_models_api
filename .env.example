# ── PIBot Serving – Environment Variables ──────────────────────
# Copy to .env and adjust values for your environment.

# ── Model source ──────────────────────────────────────────────
# Option A: Load from Hugging Face Hub (recommended for production)
MODEL_SOURCE=huggingface
HF_REPO_ID=smenaaliaga/pibert
# HF_TOKEN=hf_xxx            # only needed for private repos

# Option B: Load from a local directory
# MODEL_SOURCE=local
# MODEL_LOCAL_DIR=/app/model  # absolute path inside the container

# ── Inference ─────────────────────────────────────────────────
MAX_SEQ_LEN=64
DEVICE=auto                   # auto | cpu | cuda | mps

# ── Server ────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1                 # 1 worker when GPU; scale with CPU
LOG_LEVEL=info                # debug | info | warning | error
CORS_ORIGINS=["*"]            # JSON array of allowed origins

# ── Observability ─────────────────────────────────────────────
ENABLE_METRICS=true           # /metrics (Prometheus)
